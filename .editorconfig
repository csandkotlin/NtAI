root = true

# Mặc định: KHÔNG kiểm tra gì cả
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = false
insert_final_newline = false

# CHỈ kiểm tra file C#
[*.cs]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# Bỏ qua file YAML, JSON, MD...
[{*.yml,*.yaml,*.json,*.md}]
indent_style = ignore
indent_size = ignore
trim_trailing_whitespace = ignore
insert_final_newline = ignore
